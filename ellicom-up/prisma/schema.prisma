datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}





enum JobStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum JobType {
  PHOTOCOPY
  PRINTING
  LARGE_FORMAT
  SCANNING
  OTHER
}

model Role {
  id    String  @id @default(cuid())
  name  String  @unique

  users User[]
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  roleId    String
  role      Role     @relation(fields: [roleId], references: [id])

  jobs      Job[]    // Internal jobs submitted by staff
}

model Client {
  id        String   @id @default(cuid())
  name      String
  email     String?  @unique
  phone     String?
  company   String?
  address   String?

  jobs      Job[]    // External jobs submitted by client
}

model Job {
  id          String     @id @default(cuid())
  title       String
  description String?
  type        JobType
  status      JobStatus  @default(PENDING)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  // Optional: submitted by internal User
  userId      String?
  user        User?       @relation(fields: [userId], references: [id])

  // Optional: submitted by external Client
  clientId    String?
  client      Client?     @relation(fields: [clientId], references: [id])

  // Optional future extensions:
  // invoice     Invoice?   @relation(fields: [invoiceId], references: [id])
  // invoiceId   String?
}
