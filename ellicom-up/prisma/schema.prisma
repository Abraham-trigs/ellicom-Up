generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPERADMIN
  ADMIN
  SECRETARY
  STAFF
  CLIENT
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  password     String
  phone        String?
  role         Role
  totalRevenue Decimal  @default(0.0)
  totalJobs    Int      @default(0)
  createdAt    DateTime @default(now())

  // Relations
  createdJobs  Job[]    @relation("JobsCreated") // jobs created by this user (client or staff)
  handledJobs  Job[]    @relation("JobsHandled") // jobs assigned to this user (internal only)
}

model Job {
  id           String   @id @default(cuid())
  title        String
  details      String?
  status       String   @default("pending")
  createdAt    DateTime @default(now())

  // Who created the job (any user: client or internal)
  createdBy     User   @relation("JobsCreated", fields: [createdById], references: [id])
  createdById   String

  // Who is handling the job (internal users only: optional)
  handledBy     User?  @relation("JobsHandled", fields: [handledById], references: [id])
  handledById   String?
}
